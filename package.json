{
  "name": "bijbrengen-ecosystem",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "landing-site",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build:landing",
    "dev:landing": "npm --workspace landing-site run dev",
    "build:landing": "npm --workspace landing-site run build",
    "preview:landing": "npm --workspace landing-site run preview",
    "dev:phile": "npm --workspace @bijbrengen/phile-tool run dev",
    "build:phile": "npm --workspace @bijbrengen/phile-tool run build",
    "preview:phile": "npm --workspace @bijbrengen/phile-tool run preview"
  },
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=11.0.0"
  },
  "overrides": {
    "vite": "^7.3.5"
  }
}
