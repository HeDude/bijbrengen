---
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import OfferSection from "../components/OfferSection.astro";
import SubsidyNotice from "../components/SubsidyNotice.astro";
import Footer from "../components/Footer.astro";
import { sections } from "../data/homepage.js";
import "../styles/global.css";
---

<!DOCTYPE html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Stichting Bijbrengen verbindt zorg, coaching en onderwijs rond vrij leren." />
    <meta name="viewport" content="width=device-width" />
    <title>Bijbrengen</title>
    <script is:inline data-goatcounter="https://bijbrengen.goatcounter.com/count" async src="//gc.zgo.at/count.js"></script>
  </head>
  <body>
    <div class="page-shell">
      <Header />
      <Hero />
      <SubsidyNotice />
      {sections.map((section) => <OfferSection section={section} />)}
      <Footer />
    </div>
  </body>
</html>
