---
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import SubsidyNotice from "../components/SubsidyNotice.astro";
import Footer from "../components/Footer.astro";
import { teasers } from "../data/homepage.js";
import "../styles/global.css";

const base = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Stichting Bijbrengen verbindt zorg, coaching en onderwijs rond vrij en ondernemend leren. Ontdek onze initiatieven zoals Leerpretpark.nl." />
    <meta name="viewport" content="width=device-width" />
    <title>Bijbrengen - Samen leren, groeien en innoveren</title>
    <script is:inline data-goatcounter="https://bijbrengen.goatcounter.com/count" async src="//gc.zgo.at/count.js"></script>
  </head>
  <body>
    <div class="page-shell">
      <Header />
      <Hero />
      <SubsidyNotice />
      
      <section class="teaser-section">
        <div class="teaser-section__inner">
          <div class="teaser-section__intro">
            <h2>Onze kernpijlers</h2>
            <p>
              Stichting Bijbrengen werkt op het raakvlak van persoonlijke ontwikkeling, vernieuwend onderwijs en technologische innovatie. Ontdek hieronder onze belangrijkste pijlers.
            </p>
          </div>
          <div class="teaser-grid">
            {teasers.map((teaser) => (
              <article class="teaser-card" id={teaser.id}>
                <div class="teaser-card__media">
                  {teaser.image && (
                    <img
                      src={`${base}${teaser.image}`}
                      alt=""
                      width="80"
                      height="80"
                      loading="lazy"
                      decoding="async"
                    />
                  )}
                  <h3>{teaser.title}</h3>
                </div>
                <p>{teaser.description}</p>
                <div class="teaser-card__actions">
                  <a href={`${base}${teaser.ctaHref}`} class="btn btn--secondary btn--full">
                    {teaser.ctaLabel}
                  </a>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <Footer />
    </div>
  </body>
</html>
