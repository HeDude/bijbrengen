                  <button class="accordion-header js-accordion-header" style="width: 100%; display: flex; justify-content: space-between; align-items: center; padding: 1.25rem 1.5rem; font-size: 1.1rem; font-weight: 700; background: #fafafa; border: none; cursor: pointer; text-align: left; transition: background 0.2s;">
