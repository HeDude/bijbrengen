interface DocFile {
  name: string;
  fileName: string;
  path: string;
  category: string;
}

// Helper to recursively find files in a directory
function getFilesRecursively(dir: string, baseDirName: string): DocFile[] {
  let results: DocFile[] = [];
  if (!fs.existsSync(dir)) return results;
  
  const list = fs.readdirSync(dir);
  list.forEach((file: string) => {
    if (file.startsWith('.')) return; // Ignore hidden files like .htaccess
    const filePath = path.join(dir, file);
    const stat = fs.statSync(filePath);
    
    if (stat && stat.isDirectory()) {
      results = results.concat(getFilesRecursively(filePath, baseDirName));
    } else {
      const relativePath = path.relative("public", filePath).replace(/\\/g, "/");
      const rawName = file.replace(/\.[^/.]+$/, "").replace(/_/g, " ");
      const name = rawName.split(" ").map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(" ");
      const parentDir = path.dirname(filePath);
      const category = path.basename(parentDir);
      
      results.push({
        name,
        fileName: file,
        path: relativePath,
        category: category === baseDirName ? "Algemeen" : category
      });
    }
  });
  return results;
}

// Read documents and newsletters directories dynamically
const docsDir = path.resolve("public/entreprenasium/doc");
const newsDir = path.resolve("public/entreprenasium/nieuws");

const allDocs = getFilesRecursively(docsDir, "doc");
const allNews = getFilesRecursively(newsDir, "nieuws");

// Group documents by their subdirectories
const docsByCategory = allDocs.reduce((acc: Record<string, DocFile[]>, file: DocFile) => {
  if (file.category === "wikibooks") return acc;
  if (!acc[file.category]) {
    acc[file.category] = [];
  }
  acc[file.category].push(file);
  return acc;
}, {});

