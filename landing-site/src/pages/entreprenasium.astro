          </div>
        </section>

        <!-- Document Library (Accordeons) -->
        <section id="doc-library" class="about-section" style="padding: 5rem 1.25rem;">
          <div class="about-section__inner" style="max-width: 54rem;">
            <h2 class="text-center" style="margin-bottom: 1rem; font-size: 2rem;">Archief</h2>
            <p class="text-center" style="color: #64748b; margin-bottom: 3.5rem; max-width: 36rem; margin-inline: auto;">
              Blader door ons openbare archief van brochures, handleidingen, infobladen en nieuwsbrieven.
