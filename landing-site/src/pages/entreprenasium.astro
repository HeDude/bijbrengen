                    <div style="display: flex; justify-content: flex-end; align-items: center;">
                      <!-- Leerling Icon SVG -->
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#F26522" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"></path></svg>
                    </div>
                    <h3 style="font-size: 1.2rem; font-weight: 700; color: #172026; margin: 0;">{course.name}</h3>
                    <p style="color: #64748b; font-size: 0.9rem; line-height: 1.5; margin: 0;">{course.summary}</p>
