---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

const base = import.meta.env.BASE_URL;

const sourceLinks = [
  { label: "GitHub", href: "https://github.com/HeDude", icon: "github.svg" },
  { label: "Code", href: "https://github.com/HeDude/hedude.github.io", icon: "code.svg" },
  { label: "Wiki", href: "https://github.com/HeDude/hedude.github.io/wiki", icon: "wiki.svg" }
];

const modules = [
  {
    title: "Freell",
    longTitle: "FREE Learning Language",
    href: "https://github.com/HeDude/Freell",
    image: "freell-bg.png",
    description:
      "Freell helpt onderwijsregels en leerontwerp zo te beschrijven dat AI en software ermee kunnen werken. Het doel is minder onnodige beperkingen en meer vrijheid in leertrajecten."
  },
  {
    title: "Lega",
    longTitle: "LEarnGAme",
    href: "https://github.com/HeDude/Lega",
    image: "lega-bg.png",
    description:
      "Lega verkent hoe speelse systemen leerlingen kunnen helpen om beter te leren leren. Door spel ontstaat ruimte om eigen strategieen te ontdekken en leerprocessen bewuster te ontwerpen."
  },
  {
    title: "Edar",
    longTitle: "EDucation ARchitect",
    href: null,
    image: "edar-bg.png",
    description:
      "Edar ondersteunt onderwijsarchitecten bij het ontwerpen, beheren en verbeteren van vrije leerprogramma's. De tool richt zich op overzicht, ontwerpvrijheid en praktische uitvoerbaarheid."
  },
  {
    title: "Edda",
    longTitle: "EDucator's DAshboard",
    href: null,
    image: "edda-bg.png",
    description:
      "Edda maakt individuele en groepsroutes inzichtelijk. Daardoor kunnen begeleiders leerlingen meer vrijheid geven en toch zien waar ondersteuning nodig is."
  }
];
---

<!DOCTYPE html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="HeDude is de technische en AI-gerichte dienst van Bijbrengen voor vrij leren, leerontwerp en educatieve software."
    />
    <meta name="viewport" content="width=device-width" />
    <title>HeDude - Stichting Bijbrengen</title>
    <script is:inline data-goatcounter="https://bijbrengen.goatcounter.com/count" async src="//gc.zgo.at/count.js"></script>
  </head>
  <body>
    <div class="page-shell">
      <Header />

      <main class="main-content hedude-page">
        <section class="hedude-hero" style={`--hedude-bg: url('${base}hedude/images/hedude_bg.png')`}>
          <div class="hedude-hero__inner">
            <div class="hedude-hero__copy">
              <span class="badge">Dienst</span>
              <h1>HeDude</h1>
              <p>
                HeDude staat voor Hosting EDUcation DEsign: de technische werkplaats rond
                vrij leren, AI-coaching en onderwijssoftware binnen Bijbrengen.
              </p>
              <div class="hedude-hero__links" aria-label="HeDude bronnen">
                {sourceLinks.map((link) => (
                  <a href={link.href} target="_blank" rel="noopener noreferrer" class="btn btn--secondary">
                    <img src={`${base}hedude/images/${link.icon}`} alt="" width="18" height="18" loading="lazy" decoding="async" />
                    {link.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        </section>

        <section class="hedude-section" aria-labelledby="hedude-modules-heading">
          <div class="hedude-section__inner">
            <div class="hedude-section__intro">
              <h2 id="hedude-modules-heading">De HeDude-modules</h2>
              <p>
                HeDude bestaat uit vier bouwblokken die als samenhangend dienstenpakket
                ingezet worden voor leerontwerp en experimentele educatieve tooling.
              </p>
            </div>
            <ul class="hedude-module-grid" role="list">
              {modules.map((module) => (
                <li class={`hedude-module-card${!module.href ? ' hedude-module-card--disabled' : ''}`}>
                  <a href={module.href ?? undefined} target={module.href ? "_blank" : undefined} rel={module.href ? "noopener noreferrer" : undefined} aria-disabled={!module.href ? "true" : undefined} style={!module.href ? "pointer-events:none;opacity:0.45;cursor:default;" : ""}>
                    <figure>
                      <img
                        src={`${base}hedude/images/${module.image}`}
                        alt=""
                        width="900"
                        height="900"
                        loading="lazy"
                        decoding="async"
                      />
                      <figcaption>{module.title}</figcaption>
                    </figure>
                    <div class="hedude-module-card__copy">
                      <h3>{module.longTitle}</h3>
                      <p>{module.description}</p>
                    </div>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </section>

        <section class="hedude-architecture" aria-labelledby="hedude-architecture-heading">
          <div class="hedude-architecture__inner">
            <div class="hedude-architecture__copy">
              <span class="badge">Architectuur</span>
              <h2 id="hedude-architecture-heading">Van onderwijsvisie naar werkende tools</h2>
              <p>
                HeDude verbindt taal voor leerregels, spelvormen, ontwerpsoftware en dashboards.
                Daarmee wordt het mogelijk om vrije leertrajecten niet alleen te beschrijven,
                maar ook te bouwen, te testen en te verbeteren.
              </p>
            </div>
            <div class="hedude-architecture__media">
              <img
                src={`${base}hedude/images/interaction_flow.svg`}
                alt="Interactiestroom tussen HeDude onderdelen"
                width="960"
                height="540"
                loading="lazy"
                decoding="async"
              />
            </div>
          </div>
        </section>
      </main>

      <Footer />
    </div>
  </body>
</html>

<style>
  .hedude-page {
    background: #ffffff;
  }

  .hedude-hero {
    position: relative;
    overflow: hidden;
    min-height: 38rem;
    background:
      linear-gradient(90deg, rgb(255 255 255 / 0.95) 0%, rgb(255 255 255 / 0.88) 42%, rgb(255 255 255 / 0.2) 100%),
      var(--hedude-bg) center right / cover no-repeat;
  }

  .hedude-hero__inner {
    max-width: 72rem;
    margin-inline: auto;
    padding: 8rem 1.25rem 5rem;
  }

  .hedude-hero__copy {
    max-width: 40rem;
  }

  .hedude-hero h1 {
    margin: 0;
    color: #111827;
    font-size: clamp(3.25rem, 8vw, 6rem);
    font-weight: 800;
    line-height: 0.95;
  }

  .hedude-hero p {
    margin: 1.5rem 0 0;
    color: #475569;
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    font-weight: 520;
    line-height: 1.7;
  }

  .hedude-hero__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .hedude-hero__links .btn {
    gap: 0.5rem;
  }

  .hedude-section,
  .hedude-architecture {
    border-top: 1px solid #e5e7eb;
    padding: 5rem 1.25rem;
  }

  .hedude-section__inner,
  .hedude-architecture__inner {
    max-width: 72rem;
    margin-inline: auto;
  }

  .hedude-section__intro,
  .hedude-architecture__copy {
    max-width: 44rem;
    margin-bottom: 2rem;
  }

  .hedude-section h2,
  .hedude-architecture h2 {
    margin: 0;
    color: #111827;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 740;
    line-height: 1.1;
  }

  .hedude-section p,
  .hedude-architecture p {
    margin: 1rem 0 0;
    color: #64748b;
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .hedude-module-grid {
    display: grid;
    gap: 1.25rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .hedude-module-card {
    min-height: 100%;
    overflow: hidden;
    border: 1px solid #e5e7eb;
    border-radius: 0.5rem;
    background: #ffffff;
    transition: border-color 160ms ease, box-shadow 160ms ease, transform 160ms ease;
  }

  .hedude-module-card:hover {
    border-color: rgb(190 18 60 / 0.28);
    box-shadow: 0 16px 36px rgb(15 23 42 / 0.1);
    transform: translateY(-2px);
  }

  .hedude-module-card a {
    display: grid;
    min-height: 100%;
    color: inherit;
    text-decoration: none;
  }

  .hedude-module-card figure {
    position: relative;
    margin: 0;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #111827;
  }

  .hedude-module-card figure::after {
    position: absolute;
    inset: 0;
    content: "";
    background: linear-gradient(180deg, transparent 35%, rgb(0 0 0 / 0.7));
  }

  .hedude-module-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hedude-module-card figcaption {
    position: absolute;
    z-index: 1;
    inset: auto 1rem 1rem;
    color: #ffffff;
    font-size: 2rem;
    font-weight: 800;
  }

  .hedude-module-card__copy {
    padding: 1.25rem;
  }

  .hedude-module-card h3 {
    margin: 0;
    color: #111827;
    font-size: 1.2rem;
    font-weight: 720;
  }

  .hedude-module-card p {
    margin: 0.75rem 0 0;
    color: #64748b;
    font-size: 0.95rem;
    line-height: 1.65;
  }

  .hedude-architecture {
    background: #fafaf7;
  }

  .hedude-architecture__inner {
    display: grid;
    gap: 2rem;
    align-items: center;
  }

  .hedude-architecture__media {
    border: 1px solid #e5e7eb;
    border-radius: 0.5rem;
    background: #ffffff;
    padding: 1rem;
    box-shadow: 0 16px 36px rgb(15 23 42 / 0.08);
  }

  .hedude-architecture__media img {
    width: 100%;
    height: auto;
  }

  @media (min-width: 780px) {
    .hedude-module-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .hedude-architecture__inner {
      grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
    }
  }

  @media (min-width: 1080px) {
    .hedude-module-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }
</style>
