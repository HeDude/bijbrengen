---
import { navigation } from "../data/homepage.js";

const base = import.meta.env.BASE_URL;

const getHref = (href: string) => {
  if (href === "/") {
    return base;
  }

  if (href.startsWith("http") || href.startsWith("mailto:") || href.startsWith("#")) {
    return href;
  }

  return `${base}${href}`;
};
---

<header class="site-header">
  <div class="site-header__inner">
    <a href={base} class="site-header__brand">
      <img
        src={`${base}media/logos/bijbrengen.svg`}
        alt="Bijbrengen"
        width="218"
        height="86"
        loading="eager"
        decoding="async"
      />
    </a>
    <nav class="site-nav" aria-label="Hoofdnavigatie">
      <ul class="site-nav__list" role="list">
        {navigation.map((item) => {
          if (item.items) {
            return (
              <li class="site-nav__item site-nav__item--group">
                <details class="site-nav__group">
                  <summary class="site-nav__summary">
                    <span>{item.label}</span>
                    <span class="site-nav__chevron" aria-hidden="true"></span>
                  </summary>
                  <ul class="site-nav__submenu" role="list">
                    {item.items.map((subItem) => (
                      <li>
                        <a
                          href={getHref(subItem.href)}
                          class="site-nav__submenu-link"
                          target={subItem.external ? "_blank" : undefined}
                          rel={subItem.external ? "noopener noreferrer" : undefined}
                        >
                          {subItem.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </details>
              </li>
            );
          }

          const href = getHref(item.href);
          return (
            <li class="site-nav__item">
              <a href={href} class="site-nav__link">{item.label}</a>
            </li>
          );
        })}
      </ul>
    </nav>
  </div>
</header>
