---
import { navigation } from "../data/homepage.js";

const base = import.meta.env.BASE_URL;
---

<header class="site-header">
  <div class="site-header__inner">
    <a href={base} class="site-header__brand">
      <img
        src={`${base}media/logos/bijbrengen.svg`}
        alt="Bijbrengen"
        width="218"
        height="86"
        loading="eager"
        decoding="async"
      />
    </a>
    <nav class="site-nav" aria-label="Hoofdnavigatie">
      <ul class="site-nav__list" role="list">
        {navigation.map((item) => {
          const href = item.href === "/" ? base : `${base}${item.href}`;
          return (
            <li class="site-nav__item">
              <a href={href} class="site-nav__link">{item.label}</a>
            </li>
          );
        })}
      </ul>
    </nav>
  </div>
</header>
